# Ephemeral kit scratch: subagent reports, captured diffs, repro artifacts.
# Working artifacts are never committed; the plan's Chapter is the durable record.
.kit/

# Machine-local harness state: per-machine permission grants and worktrees.
.claude/settings.local.json
.claude/worktrees/

# Built plugin artifact: regenerated by build.ps1 / build.sh (and the pre-commit
# hook) and carried by hand for upload. Never tracked.
plugins/claude-kit.zip

# Build stamp: written by build.ps1 / build.sh into the packaged plugin so the
# kit-version-nudge hook can identify a session's build. Regenerated every build,
# never tracked (a committed stamp would churn and lie).
plugins/claude-kit/.claude-plugin/build-info.json
